   ],
   "source": [
    "# Предполагаем, что 'user_id' — это колонка с идентификаторами пользователей\n",
    "users_in_visits = set(df_visits['user_id'])\n",
    "users_in_orders = set(df_orders['user_id'])\n",
    "\n",
    "# Находим пересечение пользователей\n",
    "common_users = users_in_visits.intersection(users_in_orders)\n",
    "\n",
    "print(\"Количество пользователей, которые есть в обоих датафреймах:\", len(common_users))\n",
    "\n",
    "# Выводим список пользователей в каждом датафрейме\n",
    "print(\"Список пользователей в df_visits:\")\n",
