    "# Объединяем CAC с основными данными first_sessions в profiles\n",
    "profiles = pd.merge(\n",
    "    first_sessions,\n",
    "    cohort_costs[['date', 'first_channel', 'cac']],\n",
    "    on=['date', 'first_channel'],\n",
    "    how='left')\n",
    "display(profiles)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 37,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Удаляем временную колонку date\n",
    "profiles.drop('date', axis=1, inplace=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 38,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Заполняем нулями CAC для пользователей без затрат\n",
    "profiles['cac'] = profiles['cac'].fillna(0)"
   ]
  },
