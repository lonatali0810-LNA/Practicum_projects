   "source": [
    "# Считаем конверсию в покупку за 28 дней\n",
    "# Формируем когорты по неделям привлечения, берем платящих пользователей из датафрейма df_orders_28, совершённые в течение первых 28 дней после привлечения\n",
    "df_orders_28d = df_orders_28.copy()\n",
    "df_orders_28d['first_week']= df_orders_28d['first_dt'].dt.to_period('W').dt.to_timestamp()\n",
    "display(df_orders_28d)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 85,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Считаем платящих пользователей в первые 28 дней по недельной когорте и каналу\n",
    "paying_users_28d = df_orders_28d.groupby(['first_week','first_channel'])['user_id'].nunique().reset_index().rename(columns={'user_id': 'paying_users_28d'})"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 86,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Объединяем количество привлеченных пользователей с платящими пользователей в первые 28 дней по недельной когорте и каналу\n",
    "weekly_metrics = base_cohort.merge(paying_users_28d, on=['first_week', 'first_channel'], how='left')\n",
    "weekly_metrics['paying_users_28d'] = weekly_metrics['paying_users_28d'].fillna(0)"
   ]
  },
