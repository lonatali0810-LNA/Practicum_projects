   "source": [
    "# Объединяем размеры когорт с_week_ltv\n",
    "week_ltv_user = week_ltv.merge(week_cohort_base, on=['first_week', 'first_channel'], how='left')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 117,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Вычисляем LTV\n",
    "week_ltv_user['LTV'] = week_ltv_user['revenue_cum'] /week_ltv_user['cohort_size']"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 118,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Расчет ROI\n",
    "week_ltv_user['ROI'] = (week_ltv_user['LTV'] - week_ltv_user['cac_mean']) / week_ltv_user['cac_mean'] * 100"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 119,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Преобразуем к дате, отбросив время\n",
    "week_ltv_user['first_week'] = week_ltv_user['first_week'].dt.date"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 120,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Выделяем каналы для которых не получилось вычислить ROI на более коротком периоде\n",
    "channel = ['TipTop', 'FaceBoom']"
   ]
  },
  {
   "cell_type": "code",
