  {
   "cell_type": "code",
   "execution_count": 110,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Сортируем значения\n",
    "df_orders_week = df_orders_week.sort_values(['first_channel','first_week', 'lifetime_week']).reset_index(drop=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 111,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Считаем выручку\n",
    "# Вычисляем недельную сумму выручки\n",
    "week_ltv = (\n",
    "    df_orders_week[df_orders_week['lifetime_week'] < 10]\n",
    "    .groupby(['first_week', 'first_channel', 'lifetime_week'])['revenue'].sum().reset_index()\n",
    "    .sort_values(['first_week', 'first_channel', 'lifetime_week'])\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 112,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Вычисляем кумулятивную сумму\n",
    "week_ltv['revenue_cum'] = week_ltv.groupby(['first_week','first_channel'])['revenue'].cumsum()"
   ]
  },
