   "source": [
    "# Cчитаем LTV, \n",
    "# У нас есть датафрейм base_cohort - кол-во привлеченных пользователей на первый день\n",
    "display(base_cohort)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 97,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Берем датафрейм df_orders_28, где отфильтрованы покупки, совершенные за 28 дней\n",
    "# Выделяем недельные когорты \n",
    "df_orderss_28 = df_orders_28.copy()\n",
    "df_orderss_28['first_week'] = pd.to_datetime(df_orders_28['first_dt']).dt.to_period('W').dt.to_timestamp()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 98,
   "metadata": {},
   "outputs": [],
   "source": [
    "# # Суммарная выручка за 28 дней по когорте и каналам\n",
    "week_ltv = df_orderss_28.groupby(['first_week', 'first_channel'])['revenue'].sum().reset_index()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 99,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Объединяем\n",
    "week_ltv = week_ltv.merge(base_cohort, on=['first_week', 'first_channel'], how='left')\n",
    "\n",
    "# Считаем LTV (на пользователя)\n",
    "week_ltv['ltv_28'] = week_ltv['revenue'] / week_ltv['cohort_size']"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 100,
   "metadata": {
    "scrolled": false
   },
