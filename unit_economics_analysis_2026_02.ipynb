      "Index(['month_cohort', 'revenue'], dtype='object')\n"
     ]
    }
   ],
   "source": [
    "# Считаем LTV\n",
    "# Группируем выручку по месяцам \n",
    "monthly_revenue = df_orders_28.groupby('month_cohort')['revenue'].sum().reset_index()\n",
    "print(monthly_revenue.columns)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 59,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Рассчитываем средний CAC для каждой когорты\n",
    "cohort_cac = profiles.groupby('month_cohort')['cac'].mean().reset_index()\n",
    "cohort_cac.columns = ['month_cohort', 'cac_mean']"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 60,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Рассчитываем размер каждой когорты по месяцам\n",
    "cohort_sizes = profiles.groupby('month_cohort')['user_id'].nunique().reset_index()\n",
    "cohort_sizes.columns = ['month_cohort','cohort_size']"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 61,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Объединяем размер когорт и CAC\n",
    "df_cohort_metrics = cohort_sizes.merge(cohort_cac, on='month_cohort', how='left')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 62,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Объединяем все данные -  выручку со всеми пользователями\n",
    "df_final = monthly_revenue.merge(df_cohort_metrics, on='month_cohort', how='left')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 63,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Рассчитываем LTV (выручка / размер когорты)\n",
    "df_final['ltv_28'] = df_final['revenue'] / df_final['cohort_size']"
   ]
  },
