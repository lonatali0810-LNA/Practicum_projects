   "execution_count": 51,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Объединяем MAU и среднемесячный DAU для расчета Stickiness\n",
    "stickiness_table = pd.merge(mau_total, dau_monthly_average, how='left', on='month')\n",
    "stickiness_table['Stickiness'] = stickiness_table['DAU'] / stickiness_table['MAU']*100"
   ]
