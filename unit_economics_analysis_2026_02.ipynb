   "source": [
    "# Преобразуем first_dt в формат даты, отбросив время\n",
    "profiles['first_dt'] = profiles['first_dt'].dt.date\n",
    "\n",
    "# Считаем пользователдей по дням в разрезе каждого источника\n",
    "total_users_channel = profiles.groupby(['first_dt', 'first_channel'], as_index=False)['user_id'].nunique()\n",
    "\n",
    "# Визуализируем, создаем график\n",
    "plt.subplots(figsize=(14,5))\n",
    "\n",
    "# Проходим по каждому каналу и строим график\n",
    "for channel in total_users_channel['first_channel'].unique():\n",
    "    df_plot = total_users_channel[total_users_channel['first_channel'] == channel]\n",
    "    plt.plot(df_plot['first_dt'], df_plot['user_id'], label=channel)\n",
    "\n",
    "plt.title('Динамика набора новых пользователей в разрезе каналов по дням')\n",
    "plt.xlabel('День привлечения')\n",
    "plt.ylabel('Количество новых пользователей')\n",
    "plt.legend() \n",
    "plt.grid()\n",
    "plt.show()"
   ]
  },
