   "source": [
    "from matplotlib import colors as mcolors\n",
    "\n",
    "# Визуализируем\n",
    "# Определяем палитру\n",
    "cmap = mcolors.LinearSegmentedColormap.from_list('green_red', ['#FF3333', '#FFFF66', '#4C9900'], N=100)\n",
    "\n",
    "# Строим график\n",
    "for c in channel:\n",
    "    df_pivot_roi = (\n",
    "        week_ltv_user[week_ltv_user['first_channel'] == c]\n",
    "        .pivot(index='first_week', columns='lifetime_week', values='ROI')\n",
    "    )\n",
    "    \n",
    "    # Создаём график\n",
    "    plt.figure(figsize=(16, 10))\n",
    "    \n",
    "    # Строим heatmap с палитрой\n",
    "    sns.heatmap(\n",
    "        df_pivot_roi,\n",
    "        cmap=cmap,\n",
    "        annot=True,\n",
    "        fmt='.0f',\n",
    "        linewidths=2,\n",
    "        annot_kws={\"size\": 12}\n",
    "    )\n",
    "    \n",
    "    plt.title(f'ROI по неделям, {c}')\n",
    "    plt.xlabel('Период')\n",
    "    plt.ylabel('Когорта')\n",
    "    plt.show() "
   ]
