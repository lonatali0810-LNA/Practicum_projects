   "source": [
    "# Общая визуализация LTV и CAC \n",
    "\n",
    "# Создаем график \n",
    "plt.figure(figsize=(14, 6))\n",
    "\n",
    "# Получаем уникальные каналы из данных LTV\n",
    "channels = week_ltv['first_channel'].unique()\n",
    "\n",
    "# Проходим по каждому каналу\n",
    "for channel in channels:\n",
    "    # Фильтруем данные для текущего канала\n",
    "    df_ltv = week_ltv[week_ltv['first_channel'] == channel]\n",
    "    df_cac = week_CAC_mean[week_CAC_mean['first_channel'] == channel]\n",
    "\n",
    "    # Рисуем линию LTV\n",
    "    plt.plot(df_ltv['first_week'], df_ltv['ltv_28'], marker='o', label=f'{channel} (LTV)', color=plt.cm.tab10(channels.tolist().index(channel)))\n",
    "\n",
    "    # Рисуем пунктирную линию CAC тем же цветом\n",
    "    plt.plot(df_cac['first_week'], df_cac['cac_mean'], linestyle='--', label=f'{channel} (CAC)', color=plt.cm.tab10(channels.tolist().index(channel)))\n",
    "\n",
    "# Добавляем заголовок и метки осей\n",
    "plt.title('Динамика LTV и CAC за 28 дней по каналам и неделям привлечения')\n",
    "plt.xlabel('Неделя привлечения')\n",
    "plt.ylabel('Значение LTV и CAC')\n",
    "plt.legend()\n",
    "plt.grid()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "**Вывод**: RocketSuperAds и TipTop в начале периода имеют почти одинаковые показатели LTV, однако летом проявляется основной лидер - канал TipTop.\n",
    "\n",
    "MediaTornado и FaceBoom — идут примерно на одном уровне, показатели LTV невысокие. К концу года 2024 года показатели снижаются из-за отсутствия данных."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 102,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Считаем ROI\n",
    "# Соедини LTV и CAC в один датафрейм\n",
    "week_roi = week_ltv.merge(week_CAC_mean, on=['first_week', 'first_channel'], how='left')\n",
    "\n",
    "# Расчет ROI\n",
    "week_roi['roi_28'] = (week_roi['ltv_28'] - week_roi['cac_mean']) / week_roi['cac_mean'] * 100"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 103,
